  "keyFeatures": [
    "Automatic instrumentation of 100+ Node.js libraries and frameworks via plugin system",
    "Distributed tracing with context propagation across services",
    "Application Security Monitoring (AppSec) with WAF and RASP",
    "LLM Observability for AI/ML applications (OpenAI, Anthropic, LangChain, etc.)",
    "Continuous Profiler for CPU and memory profiling",
    "Data Streams Monitoring for Kafka, SQS, and other message queues",
    "Dynamic Instrumentation (Live Debugging) without redeployment",
    "OpenTelemetry compatibility for vendor-neutral instrumentation",
    "Runtime metrics collection (GC, event loop, heap)",
    "Log injection for trace-to-log correlation"
  ],
  "publicApiSurface": [
    "tracer.init(options)",
    "tracer.trace(name, fn)",
    "tracer.wrap(name, fn)",
    "tracer.startSpan(name, options)",
    "tracer.inject(spanContext, format, carrier)",
    "tracer.extract(format, carrier)",
    "tracer.scope()",
    "tracer.use(plugin, config)",
    "tracer.setUser(user)",
    "tracer.appsec",
    "tracer.llmobs",
    "tracer.dogstatsd",
    "tracer.dataStreamsCheckpointer",
    "tracer.aiguard",
    "tracer.setBaggageItem(key, value)",
    "tracer.getBaggageItem(key)",
    "tracer.getAllBaggageItems()",
    "tracer.removeBaggageItem(key)"
  ]
